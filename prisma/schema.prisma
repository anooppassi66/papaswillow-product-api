generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  expiresAt         DateTime
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "Account_userId_fkey")
}

model User {
  id                     String                   @id @default(cuid())
  name                   String
  email                  String?                  @unique
  emailVerified          DateTime?
  password               String
  createdAt              DateTime                 @default(now())
  userName               String
  firstName              String?
  lastName               String?
  phoneNumber            String?
  roleId                 Int?
  userStatus             User_userStatus          @default(active)
  updateAt               DateTime?                @db.DateTime(0)
  updateBy               String?                  @db.VarChar(255)
  accounts               Account[]
  emailVerificationToken EmailVerificationToken[]
  refreshTokens          RefreshToken[]
  resetToken             ResetToken[]
}

model RefreshToken {
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "RefreshToken_userId_fkey")
}

model ResetToken {
  token     String   @unique
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "ResetToken_userId_fkey")
}

model EmailVerificationToken {
  token     String   @unique
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "EmailVerificationToken_userId_fkey")
}

model ProductLabel {
  id                 Int                             @id @default(autoincrement())
  productLabelName   String                          @db.VarChar(255)
  description        String                          @db.VarChar(255)
  productLabelStatus ProductLabel_productLabelStatus @default(active)
  createdAt          DateTime?                       @default(now())
  createdBy          String?                         @db.VarChar(255)
  updateAt           DateTime?                       @db.DateTime(0)
  updateBy           String?                         @db.VarChar(255)
}

model ProductCollection {
  id                      Int                                       @id @default(autoincrement())
  productCollectionName   String                                    @db.VarChar(255)
  description             String                                    @db.VarChar(255)
  productCollectionStatus ProductCollection_productCollectionStatus @default(active)
  createdAt               DateTime?                                 @default(now())
  createdBy               String?                                   @db.VarChar(255)
  updateAt                DateTime?                                 @db.DateTime(0)
  updateBy                String?                                   @db.VarChar(255)
}

model ProductTags {
  id                Int                           @id @default(autoincrement())
  productTagsName   String                        @db.VarChar(255)
  description       String                        @db.VarChar(255)
  productPermalink  String                        @db.VarChar(255)  
  productTagsStatus ProductTags_productTagsStatus @default(active)
  createdAt         DateTime?                     @default(now())
  createdBy         String?                       @db.VarChar(255)
  updateAt          DateTime?                     @db.DateTime(0)
  updateBy          String?                       @db.VarChar(255)
  tagsData                    ProductWithTags[]
}

model Roles {
  id          Int              @id @default(autoincrement())
  roleName    String           @unique
  description String
  isDefault   Roles_isDefault  @default(Y)
  createdAt   DateTime?        @default(now())
  createdBy   String?
  updateAt    DateTime?
  updateBy    String?
  roleStatus  Roles_roleStatus @default(active)
  assignPermissions AssignPermissions[]
}

model Permissions {
  id                Int                           @id @default(autoincrement())
  name              String                        @db.VarChar(255)
  moduleName        String                        @db.VarChar(255)
  description       String                        @db.VarChar(255)
  flag              Permissions_flag              @default(N)
  permissionsStatus Permissions_permissionsStatus @default(active)
  createdAt         DateTime?                     @default(now())
  createdBy         String?                       @db.VarChar(255)
  updateAt          DateTime?                     @db.DateTime(0)
  updateBy          String?                       @db.VarChar(255)
}

model Product {
  id                          Int             @id @default(autoincrement())
  name                        String
  description                 String?         @db.Text
  content                     String?         @db.LongText
  status                      String          @default("published") @db.VarChar(60)
  images                      String?         @db.Text
  sku                         String?
  order                       Int             @default(0) @db.UnsignedInt
  quantity                    Int?            @db.UnsignedInt
  allowCheckoutWhenOutOfStock Int             @default(0) @db.UnsignedTinyInt
  withStorehouseManagement    Int             @default(0) @db.UnsignedTinyInt
  isFeatured                  Int             @default(0) @db.UnsignedTinyInt
  brandId                     Int             @default(0) @db.UnsignedInt
  isVariation                 Int             @default(0) @db.TinyInt
  saleType                    Int             @default(0) @db.TinyInt
  price                       Float?
  salePrice                   Float?
  startDate                   DateTime?       @db.Timestamp(0)
  endDate                     DateTime?       @db.Timestamp(0)
  length                      Float?
  wide                        Float?
  height                      Float?
  weight                      Float?
  taxId                       Int?             @default(0) @db.UnsignedInt
  views                       Int?             @default(0) @db.UnsignedInt
  createdAt                   DateTime?       @db.Timestamp(0)
  updatedAt                   DateTime?       @db.Timestamp(0)
  stockStatus                 String?         @default("in_stock")
  storeId                     Int             @db.UnsignedInt
  createdById                 Int             @default(0) @db.UnsignedInt
  createdByType               String?
  approvedBy                  Int?             @default(0) @db.UnsignedInt
  image                       String?
  productType                 String?         @default("physical") @db.VarChar(60)
  barcode                     String?         @db.VarChar(50)
  costPerItem                 Float?
  generateLicenseCode         Boolean         @default(false)
  minimumOrderQuantity        Int?            @default(0) @db.UnsignedInt
  maximumOrderQuantity        Int?            @default(0) @db.UnsignedInt
  addons                      String?         @db.Text
  discountName                String?         @db.Text
  CartItems   CartItem[]
  FavouriteItem               FavouriteItem[]
  attributesData              ProductWithAttribute[]
  lableOptions                ProductWithLabel[]
  categories                  ProductWithCategory[]
  collections                 ProductWithCollection[]
  tagsData                    ProductWithTags[]
  stockRecords                StockRecord[]
}

model FinancialYear {
  id                  Int                         @id @default(autoincrement())
  financialYear       String                      @db.VarChar(100)
  status              FinancialYear_status        @default(active)
  isDefault           FinancialYear_isDefault     @default(Y)
  createdAt           DateTime?                   @default(now())
  createdBy           String?                     @db.VarChar(100)
  updateAt            DateTime?                   @db.DateTime(0)
  updateBy            String?                     @db.VarChar(100)
}

model StockRecord {
  id                  Int               @id @default(autoincrement())
  financialYear       String            @db.VarChar(100)
  invoiceDate         DateTime
  invoiceNumber       String            @db.VarChar(100)
  storeId             Int  
  productId           Int
  productAttrId       Int
  openingstock        Int               @default(0)  
  received            Int               @default(0)
  issued              Int               @default(0)
  returned            Int               @default(0)  
  status              StockRecord_status @default(active)
  createdAt           DateTime?         @default(now())
  createdBy           String?           @db.VarChar(100)
  updateAt            DateTime?         @db.DateTime(0)
  updateBy            String?           @db.VarChar(100)

  product    Product       @relation(fields: [productId], references: [id])
  stockDetails StockDetail[]
  store     Stores @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId, financialYear, productAttrId])
}

model StockDetail {
  id                       Int                @id @default(autoincrement())
  stockRecordId            Int
  inventoryId              Int
  storeId                  Int
  financialYear            String            @db.VarChar(100)
  vendorName               String            @db.VarChar(100)
  variationName            String?            @db.VarChar(100)
  productId                Int
  productAttrId            Int
  amount                   Float?
  attributePrice           Float?
  attributeSalePrice       Float?
  received                 Int?                @default(0)
  receivedDate             DateTime?
  issued                   Int?                @default(0)
  issuedDate               DateTime?
  returned                 Int?                @default(0)
  returnedDate             DateTime?
  status                   StockDetail_status @default(active)
  createdAt                DateTime?          @default(now())
  createdBy                String?            @db.VarChar(100)
  updateAt                 DateTime?                   @db.DateTime(0)
  updateBy                 String?            @db.VarChar(100)

  stockRecord StockRecord   @relation(fields: [stockRecordId], references: [id])
}


model Inventory {
  id                  Int               @id @default(autoincrement())
  invoiceDate         DateTime
  invoiceNumber       String            @db.VarChar(100)
  inventoryAmount     Float
  customCharges       Float?
  shippingCharges     Float?
  otherCharges        Float?
  status              Inventory_status @default(pending)
  createdAt           DateTime?         @default(now())
  createdBy           String?           @db.VarChar(100)
  updateAt            DateTime?         @db.DateTime(0)
  updateBy            String?           @db.VarChar(100)
  inventoryDetails InventoryDetails[]
}

model InventoryDetails {
  id                       Int                @id @default(autoincrement())
  inventoryId              Int
  partialAmount            Float
  usdAmount                Float?
  inrAmount                Float?
  invoiceDate              DateTime
  createdAt                DateTime?          @default(now())
  createdBy                String?            @db.VarChar(100)
  updateAt                 DateTime?                   @db.DateTime(0)
  updateBy                 String?            @db.VarChar(100)

  inventory Inventory   @relation(fields: [inventoryId], references: [id])
}

model Cart {
  id     Int        @id @default(autoincrement())
  userId String
  items  CartItem[]
}

model CartItem {
  id        Int   @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int
  unitPrice Float
  productAttrId  Int  @default(0)
  Cart      Cart  @relation(fields: [cartId], references: [id])
  Product   Product @relation(fields: [productId], references: [id])
  @@index([cartId], map: "CartItem_cartId_fkey")
}

model Favourite {
  id       Int             @id @default(autoincrement())
  userId   String
  favitems FavouriteItem[]
}

model FavouriteItem {
  id        Int       @id @default(autoincrement())
  favId     Int
  productId Int
  quantity  Int
  unitPrice Float
  Favourite Favourite @relation(fields: [favId], references: [id])
  Product   Product   @relation(fields: [productId], references: [id])

  @@index([favId], map: "FavouriteItem_favId_fkey")
  @@index([productId], map: "FavouriteItem_productId_fkey")
}

model Stores {
  id           Int                @id @default(autoincrement())
  storeName    String             @unique(map: "storeName") @db.VarChar(255)
  storeUrl     String             @db.VarChar(255)
  storeEmail   String             @db.VarChar(255)
  storePhone   String             @db.VarChar(20)
  storeDesc    String             @db.Text
  storeContent String             @db.Text
  storeCountry String             @db.VarChar(255)
  storeState   String             @db.VarChar(255)
  storeCity    String             @db.VarChar(255)
  storeAddress String             @db.VarChar(255)
  storeCompany String             @db.VarChar(255)
  storeStatus  Stores_storeStatus @default(active)
  storeOwner   String             @db.VarChar(255)
  storeLogo    String?            @db.Text
  storeImages  String             @db.Text
  createdAt    DateTime?          @db.DateTime(0)
  createdBy    String?            @db.VarChar(100)
  updateAt     DateTime?          @db.DateTime(0)
  updateBy     String?            @db.VarChar(100)
  stockRecords StockRecord[] 
}

model Countries {
  id            Int                     @id @default(autoincrement())
  countryName   String                  @unique
  countryIso    String
  sortOrder     Int
  countryStatus Countries_countryStatus @default(active)
  isDefault     Countries_isDefault     @default(Y)
  createdAt     DateTime?               @default(now())
  createdBy     String?
  updateAt      DateTime?
  updateBy      String?
  states      States[]
  cities      Cities[]
}

model States {
  id             Int                @id @default(autoincrement())
  stateName      String             @unique
  stateShortName String
  countryId      Int
  stateStatus    States_stateStatus @default(active)
  isDefault      States_isDefault   @default(Y)
  createdAt      DateTime?          @default(now())
  createdBy      String?
  updateAt       DateTime?
  updateBy       String?
  cities      Cities[]
  country    Countries  @relation(fields: [countryId], references: [id])
}

model Cities {
  id            Int               @id @default(autoincrement())
  cityName      String            @unique
  cityShortName String
  countryId     Int
  stateId       Int
  cityStatus    Cities_cityStatus @default(active)
  isDefault     Cities_isDefault  @default(Y)
  createdAt     DateTime?         @default(now())
  createdBy     String?
  updateAt      DateTime?
  updateBy      String?
  country    Countries  @relation(fields: [countryId], references: [id])
  state    States  @relation(fields: [stateId], references: [id])  
}

model AssignPermissions {
  id           Int                            @id @default(autoincrement())
  roleId       Int                            @unique
  permissions  String                         @db.Text
  assignStatus AssignPermissions_assignStatus @default(active)
  createdAt    DateTime?                      @default(now())
  createdBy    String?
  updateAt     DateTime?
  updateBy     String?
  roles        Roles    @relation(fields: [roleId], references: [id]) // Example relation

}

model BillingInfo {
  id              Int       @id @default(autoincrement())
  userId          String
  address         String
  city            String
  state           String
  zipCode         String
  country         String
  createdAt       DateTime? @default(now())
  createdBy       String?
  firstName       String
  lastName        String
  phoneNumber     String
  shippingAddress String
  updateAt        DateTime?
  updateBy        String?
  addresses      itemOrder[]
}

model itemOrder {
  id            Int      @id @default(autoincrement())
  userId        String
  autoOrderId   String?
  billingInfoId Int
  paymentInfoId Int
  deliveryCharges Float?
  couponId      Int?
  couponCode    String?  @db.VarChar(100)
  totalAmount   Float
  paymentMethod     String?  @db.VarChar(100)
  createdAt     DateTime @default(now())
  createdBy     String?  @db.VarChar(100)
  couponOptions String?  @db.VarChar(100)
  couponType    String?  @db.VarChar(100)
  couponValue   String?  @db.VarChar(100)
  orderStatus   item_orderStatus @default(pending)
  itemStatus   item_itemStatus @default(pending)
  processed_date        DateTime?              @db.DateTime(0)
  shipped_date        DateTime?              @db.DateTime(0)
  delivered_date        DateTime?              @db.DateTime(0)
  cancelled_date        DateTime?              @db.DateTime(0)
  OrderDetails  OrderDetails[]
  addressInfo   BillingInfo @relation(fields: [billingInfoId], references: [id])
  @@index([billingInfoId])
}

model OrderDetails {
  id               Int      @id @default(autoincrement())
  userId           String
  orderId          Int
  cartId           Int
  productId        Int
  productAttrId    Int
  productName      String   @db.VarChar(100)
  productImage     String   @db.VarChar(100)
  productPrice     Float
  productSalePrice Float?
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime @default(now())
  createdBy        String?  @db.VarChar(100)
  financialYear    String?                      @db.VarChar(100)
  storeId          Int                         @db.UnsignedInt
  orderDetailStatus   OrderDetails_orderDetailStatus @default(pending)
  itemDetailStatus   OrderDetails_itemDetailStatus @default(pending)
  iOrders    itemOrder  @relation(fields: [orderId], references: [id])
}

model Coupons {
  id              Int                    @id @default(autoincrement())
  couponCode      String                 @unique(map: "couponCode") @db.VarChar(255)
  couponDesc      String                 @db.Text
  couponStartDate String                 @db.Text
  couponEndDate   String                 @db.Text
  couponType      String                 @db.VarChar(255)
  couponOptions   String                 @db.VarChar(255)
  couponValue     String                 @db.VarChar(255)
  isNeverExpired  Coupons_isNeverExpired @default(N)
  createdAt       DateTime?              @db.DateTime(0)
  createdBy       String?                @db.VarChar(100)
  updateAt        DateTime?              @db.DateTime(0)
  updateBy        String?                @db.VarChar(100)
  couponStatus    Coupons_couponStatus   @default(active)
}

model CouponsUserAdd {
  id         Int       @id @default(autoincrement())
  couponId   Int
  couponCode String    @db.Text
  userId     String    @db.Text
  createdAt  DateTime? @db.DateTime(0)
  createdBy  String?   @db.VarChar(100)
}

model Pages {
  id                Int                       @id @default(autoincrement())
  pageName          String
  pageContent       String                    @db.Text
  pageStatus        Pages_pageStatus          @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)
}

model ProductAttributes {
  id                Int                       @id @default(autoincrement())
  attributeName     String
  attributeDesc     String                    @db.Text
  attributeStatus   ProductAttributes_attributeStatus          @default(active)
  attributeContent  String                    @db.Text
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)
}

model ProductBrands {
  id                Int                          @id @default(autoincrement())
  brandName         String
  brandDesc         String                       @db.Text
  brandWebsite      String
  brandStatus       ProductBrands_brandStatus    @default(active)
  brandOrder        Int
  brandImage        String
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)
}

model ProductCategories {
  id                   Int                          @id @default(autoincrement())
  categoryName         String
  categoryDisplayName  String
  parentId             Int
  categoryDesc         String                       @db.Text
  categoryStatus       ProductCategories_category   @default(active)  
  menuDisplay          ProductCategories_menuDisplay   @default(N)  
  categoryOrder        Int
  categoryImage        String
  createdAt            DateTime?                 @db.DateTime(0)
  createdBy            String?                   @db.VarChar(100)
  updateAt             DateTime?                 @db.DateTime(0)
  updateBy             String?                   @db.VarChar(100)

// Self-referencing relation for category hierarchy
  parentCategory       ProductCategories? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories        ProductCategories[] @relation("CategoryHierarchy")

  // Relation to ProductWithCategory
  products             ProductWithCategory[]  
}

model PaymentTransactions {
  id                Int                            @id @default(autoincrement())
  paySessionId      String
  orderId           Int                       
  payContent        String?                        @db.Text
  payStatus         PaymentTransactions_payStatus  @default(pending)
  createdAt         DateTime?                      @db.DateTime(0)
  createdBy         String?                        @db.VarChar(100)
  updateAt          DateTime?                      @db.DateTime(0)
  updateBy          String?                        @db.VarChar(100)
}

model Taxes {
  id                Int                            @id @default(autoincrement())
  title             String
  percentage        Float?
  priority          Int?                       
  taxStatus         Taxes_taxStatus                @default(active)
  createdAt         DateTime?                      @default(now())
  updatedAt         DateTime?                      @default(now())
  createdBy         String?                   @db.VarChar(100)
  updateBy          String?                   @db.VarChar(100)
}

model ProductReviews {
  id                Int                          @id @default(autoincrement())
  reviewer          String
  userId            String
  rating            String
  productId         String
  reviewStatus      ProductReviews_reviewStatus    @default(pending)
  description       String                       @db.Text
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)
}

model ProductWithAttribute {
  id                            Int                            @id @default(autoincrement())
  attributeContent              String?                        @db.Text
  productId                     Int
  attributePrice                Float?  
  attributeSalePrice            Float?
  images                        String?                        @db.Text
  attributeSku                  String?                        @db.VarChar(100)    
  attributeCostPerItem          Float?
  attributebarcode              String?                        @db.VarChar(50)
  allowCheckoutWhenOutOfStock   Int                            @default(0) @db.UnsignedTinyInt
  withStorehouseManagement      Int             @default(0) @db.UnsignedTinyInt
  attributeQuantity             Int?            @db.UnsignedInt
  attributelength               Float?
  attributewide                 Float?
  attributeheight               Float?
  attributeweight               Float?  
  couponStartDate               String?                 @db.Text
  couponEndDate                 String?                 @db.Text
  status                        ProductWithAttribute_status    @default(active)
  isDefault                     ProductWithAttribute_isDefault  @default(N)
  createdAt                     DateTime?                      @db.DateTime(0)
  createdBy                     String?                        @db.VarChar(100)
  updateAt                      DateTime?                 @db.DateTime(0)
  updateBy                      String?                   @db.VarChar(100)
  productAttr           Product            @relation(fields: [productId], references: [id])
}

enum ProductWithAttribute_isDefault {
  Y
  N
}


model ProductWithLabel {
  id                Int                            @id @default(autoincrement())
  labelId           Int
  productId         Int
  status            ProductWithLabel_status    @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)  
  productLabel       Product            @relation(fields: [productId], references: [id])
}

enum ProductWithLabel_status {
  pending
  active
  delete
}

model ProductWithCategory {
  id                Int                            @id @default(autoincrement())
  categoryId           Int
  productId         Int
  status            ProductWithCategory_status    @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)  
  
  productCat Product @relation(fields: [productId], references: [id])
  category   ProductCategories @relation(fields: [categoryId], references: [id])
}

enum ProductWithCategory_status {
  pending
  active
  delete
}

model ProductWithCollection {
  id                Int                            @id @default(autoincrement())
  collectionId           Int
  productId         Int
  status            ProductWithCollection_status    @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)  
  productColl       Product            @relation(fields: [productId], references: [id])
}

model ProductWithTags {
  id                Int                            @id @default(autoincrement())
  tagId             Int
  productId         Int
  status            ProductWithTags_status    @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)  
  product       Product            @relation(fields: [productId], references: [id])
  tag       ProductTags  @relation(fields: [tagId], references: [id])
  @@unique([productId, tagId])
}


model HomeBanners {
  id                Int                            @id @default(autoincrement())
  bannerName        String
  bannerDesc        String?
  bannerLink        String?
  bannerImages                      String?         @db.Text
  bannerPositions   HomeBanners_bannerPositions     @default(slider)
  bannerStatus      HomeBanners_bannerStatus        @default(active)
  createdAt         DateTime?                 @db.DateTime(0)
  createdBy         String?                   @db.VarChar(100)
  updateAt          DateTime?                 @db.DateTime(0)
  updateBy          String?                   @db.VarChar(100)  
}

model Notification {
  id                         Int                            @id @default(autoincrement())
  notificationName           String
  notificationOrder          String
  notificationStatus         Notification_notificationStatus        @default(active)
  createdAt                  DateTime?                 @db.DateTime(0)
  createdBy                  String?                   @db.VarChar(100)
  updateAt                   DateTime?                 @db.DateTime(0)
  updateBy                   String?                   @db.VarChar(100)  
}


model CustomerRatings {
  id                         Int                            @id @default(autoincrement())
  customerName               String
  customerCategory           String
  customerRating             Int
  customerDescription        String?         @db.Text
  customerStatus             CustomerRatings_customerStatus        @default(active)
  createdAt                  DateTime?                 @db.DateTime(0)
